# Server Port
PORT=8000

# MongoDB Connection URI (e.g. local instance or Atlas URI)
MONGODB_URI=mongodb://127.0.0.1:27017/blast_safety

# Claude API key for AI-generated recommendations.
# If left unset, the app falls back to a templated (non-LLM) recommendation
# so it still runs end-to-end without any external dependency.
ANTHROPIC_API_KEY=

# Comma-separated list of origins allowed to call this API (CORS).
ALLOWED_ORIGINS=http://localhost:5173
